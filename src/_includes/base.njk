<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} | {{ site.shortName }}{% else %}{{ site.name }} | {{ site.tagline }}{% endif %}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.tagline }}. {{ site.address }}.{% endif %}" />
  <link rel="icon" href="{{ site.favicon }}" type="image/svg+xml" />

  <!-- Open Graph -->
  <meta property="og:title" content="{% if title %}{{ title }} | {{ site.shortName }}{% else %}{{ site.name }}{% endif %}" />
  <meta property="og:description" content="{{ site.tagline }}" />
  <meta property="og:type" content="website" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <script>document.documentElement.className += " js";</script>
  <link rel="stylesheet" href="/assets/css/styles.css" />
  <style>
    :root {
      --sage: {{ site.brandColor }};
      --sage-deep: {{ site.brandColor }};
      --gold: {{ site.accentColor }};
    }
  </style>
</head>
<body>
  {% if site.showAnnouncement and site.announcement %}
  <div class="announce">{{ site.announcement | replace("Cherry", '<a href="' + site.cherryUrl + '" target="_blank" rel="noopener">Cherry</a>') | safe }}</div>
  {% endif %}

  {% include "partials/header.njk" %}

  <main>
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}
  {% include "partials/chat.njk" %}

  <script src="/assets/js/main.js" defer></script>

  <!-- Load Netlify Identity ONLY when handling an invite/recovery link. Keeps every
       normal page load fast by not pulling the widget on public navigation. -->
  <script>
    (function () {
      var h = window.location.hash || "";
      if (/(invite_token|recovery_token|confirmation_token|email_change_token)=/.test(h)) {
        var s = document.createElement("script");
        s.src = "https://identity.netlify.com/v1/netlify-identity-widget.js";
        s.onload = function () {
          if (window.netlifyIdentity) {
            window.netlifyIdentity.on("init", function (user) {
              if (!user) {
                window.netlifyIdentity.on("login", function () { document.location.href = "/admin/"; });
              }
            });
            window.netlifyIdentity.init();
          }
        };
        document.head.appendChild(s);
      }
    })();
  </script>

  <!-- Instant navigation: prefetch internal pages on hover / touch for a snappy feel. -->
  <script>
    (function () {
      var seen = {};
      function prefetch(href) {
        if (!href || seen[href]) return; seen[href] = 1;
        var l = document.createElement("link"); l.rel = "prefetch"; l.href = href;
        document.head.appendChild(l);
      }
      function onHover(e) {
        var a = e.target.closest ? e.target.closest("a") : null;
        if (!a) return;
        var href = a.getAttribute("href");
        if (href && href.charAt(0) === "/" && !a.hasAttribute("target")) prefetch(href);
      }
      document.addEventListener("mouseover", onHover, { passive: true });
      document.addEventListener("touchstart", onHover, { passive: true });
    })();
  </script>
</body>
</html>
