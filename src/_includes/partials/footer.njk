<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        {% if site.useTextLogo %}
          <span class="brand-text">{{ site.shortName }}<span>From Heaven</span></span>
        {% else %}
          <img class="footer-logo" src="{{ site.logo }}" alt="{{ site.name }}" />
        {% endif %}
        <p style="margin-top:1.2rem; max-width:340px; color:#b6b3aa;">{{ site.tagline }}.</p>
        <p style="color:#b6b3aa;">{{ site.address }}</p>
      </div>
      <div>
        <h4>Explore</h4>
        <ul class="footer-links">
          <li><a href="/services/">Services &amp; Pricing</a></li>
          <li><a href="/financing/">Financing</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/contact/">Contact</a></li>
          <li><a href="{{ site.bookingUrl }}" target="_blank" rel="noopener">Book an Appointment</a></li>
        </ul>
      </div>
      <div>
        <h4>Connect</h4>
        <ul class="footer-links">
          <li><a href="tel:{{ site.phoneLink }}">{{ site.phone }}</a></li>
          {% if site.instagram %}<li><a href="{{ site.instagram }}" target="_blank" rel="noopener">Instagram</a></li>{% endif %}
          {% if site.facebook %}<li><a href="{{ site.facebook }}" target="_blank" rel="noopener">Facebook</a></li>{% endif %}
          {% if site.tiktok %}<li><a href="{{ site.tiktok }}" target="_blank" rel="noopener">TikTok</a></li>{% endif %}
        </ul>
        <h4 style="margin-top:1.8rem;">Policies</h4>
        <ul class="footer-links">
          <li><a href="/terms/">Terms &amp; Conditions</a></li>
          <li><a href="/privacy/">Privacy Policy</a></li>
          <li><a href="/refund-policy/">Refund Policy</a></li>
          <li><a href="/medical-disclaimer/">Medical Disclaimer</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; {% year %} {{ site.name }}. All rights reserved.</span>
      <span>Services administered by licensed healthcare professionals.</span>
    </div>
  </div>
</footer>
